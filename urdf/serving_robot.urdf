<?xml version="1.0" encoding="UTF-8"?>
<robot name="serving_robot">

  <!-- ======================== -->
  <!--     BASE LINK (Chassis)  -->
  <!-- ======================== -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.40 0.35 0.15"/>
      </geometry>
      <origin xyz="0 0 0.075" rpy="0 0 0"/>
      <material name="dark_gray">
        <color rgba="0.3 0.3 0.3 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.40 0.35 0.15"/>
      </geometry>
      <origin xyz="0 0 0.075" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="15.0"/>
      <origin xyz="0 0 0.075" rpy="0 0 0"/>
      <inertia ixx="0.2" ixy="0" ixz="0" iyy="0.3" iyz="0" izz="0.25"/>
    </inertial>
  </link>

  <!-- ======================== -->
  <!--     LEFT DRIVE WHEEL     -->
  <!-- ======================== -->
  <link name="left_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.08" length="0.04"/>
      </geometry>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.08" length="0.04"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.002" ixy="0" ixz="0" iyy="0.002" iyz="0" izz="0.003"/>
    </inertial>
  </link>

  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin xyz="-0.15 0.195 0.0" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <dynamics damping="0.01" friction="0.1"/>
  </joint>

  <!-- ======================== -->
  <!--     RIGHT DRIVE WHEEL    -->
  <!-- ======================== -->
  <link name="right_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.08" length="0.04"/>
      </geometry>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.08" length="0.04"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.002" ixy="0" ixz="0" iyy="0.002" iyz="0" izz="0.003"/>
    </inertial>
  </link>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="-0.15 -0.195 0.0" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <dynamics damping="0.01" friction="0.1"/>
  </joint>

  <!-- ======================== -->
  <!--     FRONT LEFT CASTER    -->
  <!-- ======================== -->
  <link name="front_left_caster">
    <visual>
      <geometry>
        <sphere radius="0.04"/>
      </geometry>
      <material name="gray">
        <color rgba="0.5 0.5 0.5 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.04"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.0002" ixy="0" ixz="0" iyy="0.0002" iyz="0" izz="0.0002"/>
    </inertial>
  </link>

  <joint name="front_left_caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="front_left_caster"/>
    <origin xyz="0.15 0.12 -0.04" rpy="0 0 0"/>
  </joint>

  <!-- ======================== -->
  <!--     FRONT RIGHT CASTER   -->
  <!-- ======================== -->
  <link name="front_right_caster">
    <visual>
      <geometry>
        <sphere radius="0.04"/>
      </geometry>
      <material name="gray">
        <color rgba="0.5 0.5 0.5 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.04"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.0002" ixy="0" ixz="0" iyy="0.0002" iyz="0" izz="0.0002"/>
    </inertial>
  </link>

  <joint name="front_right_caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="front_right_caster"/>
    <origin xyz="0.15 -0.12 -0.04" rpy="0 0 0"/>
  </joint>

  <!-- ======================== -->
  <!--     UPPER BODY (Frame)   -->
  <!-- ======================== -->
  <link name="upper_body">
    <visual>
      <geometry>
        <box size="0.35 0.30 0.75"/>
      </geometry>
      <origin xyz="0 0 0.375" rpy="0 0 0"/>
      <material name="silver">
        <color rgba="0.75 0.75 0.78 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.35 0.30 0.75"/>
      </geometry>
      <origin xyz="0 0 0.375" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="18.0"/>
      <origin xyz="0 0 0.375" rpy="0 0 0"/>
      <inertia ixx="1.5" ixy="0" ixz="0" iyy="1.8" iyz="0" izz="0.5"/>
    </inertial>
  </link>

  <joint name="upper_body_joint" type="fixed">
    <parent link="base_link"/>
    <child link="upper_body"/>
    <origin xyz="0 0 0.15" rpy="0 0 0"/>
  </joint>

  <!-- ======================== -->
  <!--     LOWER IMU SENSOR     -->
  <!-- ======================== -->
  <link name="lower_imu">
    <visual>
      <geometry>
        <box size="0.03 0.03 0.01"/>
      </geometry>
      <material name="green">
        <color rgba="0.0 0.8 0.0 1.0"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.02"/>
      <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
    </inertial>
  </link>

  <joint name="lower_imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lower_imu"/>
    <origin xyz="0.18 0 0.08" rpy="0 0 0"/>
  </joint>

  <!-- ======================== -->
  <!--     TRAY (Top Platform)  -->
  <!-- ======================== -->
  <link name="tray">
    <visual>
      <geometry>
        <cylinder radius="0.20" length="0.02"/>
      </geometry>
      <material name="white">
        <color rgba="0.95 0.95 0.95 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.20" length="0.02"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="2.0"/>
      <inertia ixx="0.02" ixy="0" ixz="0" iyy="0.02" iyz="0" izz="0.04"/>
    </inertial>
  </link>

  <joint name="tray_joint" type="fixed">
    <parent link="upper_body"/>
    <child link="tray"/>
    <origin xyz="0 0 0.76" rpy="0 0 0"/>
  </joint>

  <!-- ======================== -->
  <!--     UPPER IMU SENSOR     -->
  <!-- ======================== -->
  <link name="upper_imu">
    <visual>
      <geometry>
        <box size="0.03 0.03 0.01"/>
      </geometry>
      <material name="green">
        <color rgba="0.0 0.8 0.0 1.0"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.02"/>
      <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
    </inertial>
  </link>

  <joint name="upper_imu_joint" type="fixed">
    <parent link="tray"/>
    <child link="upper_imu"/>
    <origin xyz="0.10 0 0.02" rpy="0 0 0"/>
  </joint>

  <!-- ======================================= -->
  <!--     PENDULUM (Sloshing Proxy)           -->
  <!--     Revolute joint on pitch axis (Y)    -->
  <!-- ======================================= -->

  <!-- Pendulum pivot (attached to tray center) -->
  <link name="pendulum_pivot">
    <visual>
      <geometry>
        <sphere radius="0.01"/>
      </geometry>
      <material name="red">
        <color rgba="1.0 0.0 0.0 1.0"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
    </inertial>
  </link>

  <joint name="pendulum_joint" type="revolute">
    <parent link="tray"/>
    <child link="pendulum_pivot"/>
    <origin xyz="0 0 0.02" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>  <!-- pitch axis (Y-axis) -->
    <dynamics damping="0.01" friction="0.001"/>
    <limit lower="-1.57" upper="1.57" effort="0" velocity="10"/>
  </joint>

  <!-- Pendulum rod -->
  <link name="pendulum_rod">
    <visual>
      <geometry>
        <cylinder radius="0.005" length="0.15"/>
      </geometry>
      <origin xyz="0 0 -0.075" rpy="0 0 0"/>
      <material name="steel">
        <color rgba="0.6 0.6 0.6 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.005" length="0.15"/>
      </geometry>
      <origin xyz="0 0 -0.075" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <origin xyz="0 0 -0.075" rpy="0 0 0"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.00001"/>
    </inertial>
  </link>

  <joint name="pendulum_rod_joint" type="fixed">
    <parent link="pendulum_pivot"/>
    <child link="pendulum_rod"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- Pendulum mass (bob) -->
  <link name="pendulum_mass">
    <visual>
      <geometry>
        <sphere radius="0.025"/>
      </geometry>
      <material name="orange">
        <color rgba="1.0 0.5 0.0 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.025"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.50"/>
      <inertia ixx="0.0003" ixy="0" ixz="0" iyy="0.0003" iyz="0" izz="0.0003"/>
    </inertial>
  </link>

  <joint name="pendulum_mass_joint" type="fixed">
    <parent link="pendulum_rod"/>
    <child link="pendulum_mass"/>
    <origin xyz="0 0 -0.15" rpy="0 0 0"/>
  </joint>

</robot>
